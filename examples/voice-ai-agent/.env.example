# --- DialStack ---------------------------------------------------------------
# Public HTTPS URL where this server is reachable (e.g. an ngrok tunnel).
# The webhook handler uses this to compute the wss:// URL it returns to
# DialStack in the `attach` action.
PUBLIC_URL=https://your-ngrok-host.ngrok.io

# DialStack API base + key. The webhook handler calls
# POST /v1/calls/{id} to attach the audio WebSocket.
DIALSTACK_API_BASE=https://api.dialstack.ai
DIALSTACK_API_KEY=sk_live_...

# Secret used by DialStack to sign webhook payloads (HMAC-SHA256).
# Configure this when you create the Voice App.
VOICE_APP_WEBHOOK_SECRET=whsec_...

# Local listen port (default 8080).
PORT=8080

# Optional: log level (trace|debug|info|warn|error). Default: info.
LOG_LEVEL=info

# --- Provider: elevenlabs ----------------------------------------------------
# Required when `--provider elevenlabs`.
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_AGENT_ID=agent_...

# --- Provider: gemini --------------------------------------------------------
# Required when `--provider gemini`. Pick exactly ONE backend.

# (a) Google AI Studio — simplest. Get a key from https://aistudio.google.com/.
GEMINI_API_KEY=AIza...

# (b) Vertex AI — uses Application Default Credentials (gcloud auth
#     application-default login, or a workload identity setup).
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=my-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1

# Optional override; defaults are picked per backend in providers/gemini.ts.
# GEMINI_MODEL=gemini-live-2.5-flash-native-audio

# Optional system instruction for the Gemini agent.
# GEMINI_SYSTEM_PROMPT="You are a friendly receptionist for Acme Inc."

# Optional first-turn kickoff. Gemini Live waits for input before speaking,
# so we send this text right after connect to make the agent greet the
# caller without them having to speak first.
# GEMINI_KICKOFF_PROMPT="A new caller is on the line. Greet them warmly and ask how you can help."
