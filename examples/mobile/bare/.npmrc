# Install the local @dialstack/sdk `file:` dependency as a real COPY rather than a
# symlink, so this bare app resolves it exactly as an app that ran
# `npm install @dialstack/sdk` would — no reaching back into the SDK repo.
install-links=true

# react-native-webrtc / peer ranges across the RN toolchain don't all overlap
# cleanly; accept the resolution rather than block install.
legacy-peer-deps=true
