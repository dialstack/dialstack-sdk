# Install the local `file:` dependencies (@dialstack/sdk, @dialstack/sdk-native)
# as real COPIES rather than symlinks, so this example resolves them exactly as an
# app outside this repo would after `npm install @dialstack/sdk` — no reaching back
# into the SDK's own source/node_modules through a symlink.
install-links=true

# The example's Expo version is newer than one transitive plugin's declared peer
# range; accept the existing resolution rather than block install on it.
legacy-peer-deps=true
