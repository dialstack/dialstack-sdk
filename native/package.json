{
  "name": "@dialstack/sdk-native",
  "version": "0.1.0",
  "description": "React Native softphone components for the DialStack SDK",
  "license": "MIT",
  "type": "module",
  "author": "DialStack",
  "homepage": "https://github.com/dialstack/dialstack-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dialstack/dialstack-sdk.git",
    "directory": "native"
  },
  "keywords": [
    "dialstack",
    "voice",
    "softphone",
    "react-native",
    "webrtc"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "react-native": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@dialstack/sdk": "^1.2.0"
  },
  "peerDependencies": {
    "libphonenumber-js": "^1.13.6",
    "react": ">=19",
    "react-native": ">=0.81",
    "react-native-incall-manager": ">=4",
    "react-native-svg": ">=15",
    "react-native-webrtc": ">=124"
  },
  "devDependencies": {
    "@dialstack/sdk": "file:..",
    "@types/react": "~19.2.0",
    "libphonenumber-js": "^1.13.8",
    "react": "19.2.7",
    "react-native": "^0.86.0",
    "react-native-incall-manager": "^4.2.1",
    "react-native-svg": "^15.15.4",
    "react-native-webrtc": "^124.0.7",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
